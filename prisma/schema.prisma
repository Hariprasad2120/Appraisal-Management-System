model AppraisalCycle {
  id               String      @id @default(cuid())
  organizationId   String      @default("default-org")
  branchId         String?
  departmentId     String?
  userId           String
  user             User        @relation("EmpCycles", fields: [userId], references: [id])
  type             CycleType
  startDate        DateTime
  status           CycleStatus @default(PENDING_SELF)
  scheduledDate    DateTime?
  tentativeDate1   DateTime?
  tentativeDate2   DateTime?
  isManagerCycle   Boolean     @default(false)
  ratingDeadline   DateTime?
  claimedById      String?
  claimedBy        User?       @relation("CycleClaimedBy", fields: [claimedById], references: [id])
  managerId        String?
  teamLeadId       String?
  reportingToId    String?
  claimedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  self          SelfAssessment?
  assignments   CycleAssignment[]
  ratings       Rating[]
  decision      AppraisalDecision?
  extensions    ExtensionRequest[]
  auditLogs     AuditLog[]
  votes         DateVote[]
  moms                MOM[]
  ratingReviews       RatingReview[]
  ratingDisagreements RatingDisagreement[]
  arrear              Arrear?
  reschedules         MeetingReschedule[]

  @@index([userId, status])
  @@index([organizationId, status, startDate])
  @@index([organizationId, branchId, departmentId])
  @@index([organizationId, createdAt])
  @@index([startDate])
  @@index([status, claimedById])
}

model SelfAssessment {
  id             String                 @id @default(cuid())
  organizationId String                 @default("default-org")
  cycleId        String                 @unique
  cycle          AppraisalCycle         @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  answers        Json
  submittedAt    DateTime?
  lastModifiedAt DateTime?
  editableUntil  DateTime
  locked         Boolean                @default(false)
  editCount      Int                    @default(0)
  status         SelfAssessmentStatus   @default(DRAFT)

  @@index([organizationId])
}

model CycleAssignment {
  id                      String               @id @default(cuid())
  organizationId          String               @default("default-org")
  cycleId                 String
  cycle                   AppraisalCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId              String
  reviewer                User                 @relation("Reviewer", fields: [reviewerId], references: [id])
  role                    ReviewerRole
  availability            ReviewerAvailability @default(PENDING)
  availabilitySubmittedAt DateTime?
  assignedAt              DateTime             @default(now())
  assignedById            String
  assignedBy              User                 @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([cycleId, role])
  @@index([organizationId])
  @@index([reviewerId])
}

model Rating {
  id           String         @id @default(cuid())
  organizationId String       @default("default-org")
  cycleId      String
  cycle        AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User           @relation(fields: [reviewerId], references: [id])
  role         ReviewerRole
  scores           Json
  averageScore     Float
  comments         String
  postComment      String?
  submittedAt      DateTime       @default(now())
  locked           Boolean        @default(true)

  ratingReviews      RatingReview[]
  disagreement       RatingDisagreement?

  @@unique([cycleId, role])
  @@index([organizationId])
  @@index([reviewerId])
}

model DateVote {
  id        String         @id @default(cuid())
  organizationId String    @default("default-org")
  cycleId   String
  cycle     AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  voterId   String
  voter     User           @relation(fields: [voterId], references: [id])
  date      DateTime
  createdAt DateTime       @default(now())

  @@unique([cycleId, voterId])
  @@index([organizationId])
  @@index([cycleId, date])
}

model MOM {
  id        String         @id @default(cuid())
  organizationId String    @default("default-org")
  cycleId   String
  cycle     AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  /// Role perspective that owns this record: "ADMIN" | "MANAGEMENT" | "HR"
  role      String         @default("MANAGEMENT")
  content   String
  authorId  String
  author    User           @relation("MomAuthor", fields: [authorId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cycleId, role])
  @@index([organizationId])
  @@index([cycleId])
}

model AppraisalDecision {
  id                String         @id @default(cuid())
  organizationId    String         @default("default-org")
  cycleId           String         @unique
  cycle             AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  averagedRating    Float?
  finalRating       Float
  slabId            String?
  slab              IncrementSlab? @relation(fields: [slabId], references: [id])
  suggestedAmount   Decimal        @db.Decimal(12, 2)
  finalAmount       Decimal        @db.Decimal(12, 2)
  comments          String?
  managementScores  Json?
  managementComment String?
  decidedById       String
  decidedBy         User           @relation("DecidedBy", fields: [decidedById], references: [id])
  decidedAt         DateTime       @default(now())

  @@index([organizationId])
}

model IncrementSlab {
  id          String  @id @default(cuid())
  organizationId String @default("default-org")
  label       String
  grade       String  @default("")
  minRating   Float
  maxRating   Float
  salaryTier  String  @default("ALL")
  hikePercent Float

  decisions AppraisalDecision[]

  @@index([minRating, maxRating])
  @@index([organizationId, minRating, maxRating])
}

model ExtensionRequest {
  id            String          @id @default(cuid())
  organizationId String         @default("default-org")
  cycleId       String
  cycle         AppraisalCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  requesterId   String
  requester     User            @relation("ExtRequester", fields: [requesterId], references: [id])
  reason        String
  status        ExtensionStatus @default(PENDING)
  extendedUntil DateTime?
  decidedById   String?
  decidedBy     User?           @relation("ExtDecider", fields: [decidedById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([organizationId, status])
}

model Notification {
  id             String    @id @default(cuid())
  organizationId String    @default("default-org")
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  type           String
  message        String
  link           String?
  read           Boolean   @default(false)
  persistent     Boolean   @default(false)
  critical       Boolean   @default(false)
  dismissed      Boolean   @default(false)
  /// User clicked "Acknowledge" (distinct from dismiss/close)
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  /// Admin marked this as important — ignored ones can be re-triggered
  important      Boolean   @default(false)
  /// Marks a re-triggered urgent copy; persists until acknowledged
  urgent         Boolean   @default(false)
  /// Id of the original notification this was re-triggered from
  retriggeredFromId String?
  createdAt      DateTime  @default(now())
  retriggerLogs  MessageRetriggerLog[]

  @@index([userId, read])
  @@index([organizationId, createdAt])
  @@index([userId, dismissed])
  @@index([userId, critical, dismissed])
}

model LoginChallenge {
  id        String   @id @default(cuid())
  organizationId String @default("default-org")
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   @default("credentials")
  redirectTo String  @default("/")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([organizationId, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  organizationId String @default("default-org")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([organizationId, expiresAt])
}

model PasskeyResetRequest {
  id          String   @id @default(cuid())
  organizationId String @default("default-org")
  userId      String
  user        User     @relation("PasskeyResetUser", fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING")
  requestedAt DateTime @default(now())
  decidedAt   DateTime?
  decidedById String?
  decidedBy   User?    @relation("PasskeyResetDecider", fields: [decidedById], references: [id])
  reason      String?

  @@index([status, requestedAt])
  @@index([organizationId, status])
  @@index([userId, status])
}

model MessageRetriggerLog {
  id             String   @id @default(cuid())
  organizationId String   @default("default-org")
  actorId        String
  actor          User     @relation("MessageRetriggerActor", fields: [actorId], references: [id])
  recipientId    String
  recipient      User     @relation("MessageRetriggerRecipient", fields: [recipientId], references: [id])
  notificationId String?
  notification   Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  messageType    String
  channel        String
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([organizationId, createdAt])
  @@index([recipientId, createdAt])
}

model AuditLog {
  id        String          @id @default(cuid())
  organizationId String     @default("default-org")
  cycleId   String?
  cycle     AppraisalCycle? @relation(fields: [cycleId], references: [id])
  actorId   String
  actor     User            @relation(fields: [actorId], references: [id])
  action    String
  before    Json?
  after     Json?
  createdAt DateTime        @default(now())

  @@index([cycleId, createdAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, action, createdAt])
}

/// Security and access trail for login attempts plus session lifecycle events.
/// userId is nullable so failed login attempts for unknown/inactive users remain traceable.
model SecurityEvent {
  id           String   @id @default(cuid())
  organizationId String @default("default-org")
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String?
  event        String
  outcome      String
  ipAddress    String?
  userAgent    String?
  sessionToken String?
  details      Json?
  createdAt    DateTime @default(now())

  @@index([event, outcome, createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([sessionToken, createdAt])
}

/// Tracks each authenticated user session for admin monitoring.
model UserSession {
  id          String    @id @default(cuid())
  organizationId String @default("default-org")
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JWT session token identifier (sub claim or random token)
  token       String    @unique
  loginAt     DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  logoutAt    DateTime?
  /// "ACTIVE" | "TIMED_OUT" | "LOGGED_OUT"
  status      String    @default("ACTIVE")
  ipAddress   String?
  userAgent   String?
  /// Rough location from IP
  location    String?

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([status, lastSeenAt])
}

/// Admin-configurable key/value settings store.
model SystemSetting {
  id        String   @id @default(cuid())
  organizationId String @default("default-org")
  key       String
  value     String
  updatedAt DateTime @updatedAt
  updatedById String?

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([key])
}

/// Admin-editable override for criteria category questions.
/// categoryName must match a CRITERIA_CATEGORIES[].name entry.
/// questions replaces that category's default question list.
model CriteriaOverride {
  id           String   @id @default(cuid())
  organizationId String @default("default-org")
  categoryName String
  questions    Json     // string[]
  maxPoints    Int?     // override default maxPoints; null = use default
  updatedAt    DateTime @updatedAt
  updatedById  String
  updatedBy    User     @relation(fields: [updatedById], references: [id])

  @@unique([organizationId, categoryName])
  @@index([organizationId])
}

model Ticket {
  id          String         @id @default(cuid())
  organizationId String      @default("default-org")
  raisedById  String
  raisedBy    User           @relation("TicketRaiser", fields: [raisedById], references: [id])
  assigneeId  String?
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  title       String
  description String
  category    String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  cycleId     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  comments    TicketComment[]

  @@index([raisedById, status])
  @@index([organizationId, status, createdAt])
  @@index([status, createdAt])
}

model TicketComment {
  id        String   @id @default(cuid())
  organizationId String @default("default-org")
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@index([organizationId, createdAt])
}

/// Arrear record for a cycle — computed when meeting is late (>7 days after self-assessment submitted).
/// Locked once approved by management.
model Arrear {
  id            String        @id @default(cuid())
  organizationId String       @default("default-org")
  cycleId       String        @unique
  cycle         AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation("ArrearEmployee", fields: [userId], references: [id])

  /// Days from (selfSubmittedAt + 7) to scheduledDate
  arrearDays    Int
  /// Daily rate = finalAmount / 365
  dailyRate     Decimal       @db.Decimal(12, 2)
  /// arrearDays * dailyRate
  arrearAmount  Decimal       @db.Decimal(12, 2)
  /// Date from which arrear is counted (selfSubmittedAt + 7 days)
  periodFrom    DateTime
  /// Date until which arrear is counted (scheduledDate)
  periodTo      DateTime
  /// Month in which arrears will be credited (set on approval)
  payoutMonth   DateTime?

  status        ArrearStatus  @default(PENDING_APPROVAL)
  approvedById  String?
  approvedBy    User?         @relation("ArrearApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  rejectedReason String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([cycleId])
}

/// Reschedule record when a meeting does not occur on the scheduled date.
model MeetingReschedule {
  id             String           @id @default(cuid())
  organizationId String           @default("default-org")
  cycleId        String
  cycle          AppraisalCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  /// Original date that was missed
  originalDate   DateTime
  /// New proposed date
  newDate        DateTime
  reason         String
  rescheduledById String
  rescheduledBy  User             @relation("RescheduledBy", fields: [rescheduledById], references: [id])
  status         RescheduleStatus @default(PENDING)

  confirmedById  String?
  confirmedBy    User?            @relation("RescheduleConfirmer", fields: [confirmedById], references: [id])
  confirmedAt    DateTime?

  createdAt      DateTime         @default(now())

  @@index([cycleId, createdAt])
  @@index([organizationId, createdAt])
}

/// Reviewer evaluation of their own submitted rating (Accurate/Overrated/Underrated).
/// Defines negotiation ceiling for management.
model RatingDisagreement {
  id             String          @id @default(cuid())
  organizationId String         @default("default-org")
  ratingId       String          @unique
  rating         Rating          @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  cycleId        String
  cycle          AppraisalCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId     String
  reviewer       User            @relation(fields: [reviewerId], references: [id])
  evaluation     RatingEvaluation
  comment        String?         // mandatory when OVERRATED or UNDERRATED
  // Optional revised scores per criteria (JSON: {criteriaName: score})
  revisedScores  Json?
  // Negotiation ceiling (computed or manually set)
  ceilingMin     Decimal?        @db.Decimal(12, 2)
  ceilingMax     Decimal?        @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([cycleId])
  @@index([organizationId])
}

/// Post-comment review layer — reviewer can submit a revised rating per criterion
/// without overwriting the original Rating record.
model RatingReview {
  id           String   @id @default(cuid())
  organizationId String @default("default-org")
  ratingId     String
  rating       Rating   @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  cycleId      String
  cycle        AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User     @relation(fields: [reviewerId], references: [id])
  criteriaName String
  originalScore Float
  revisedScore  Float
  justification String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ratingId, criteriaName])
  @@index([organizationId])
  @@index([cycleId])
}

/// Admin-created KPI criterion with a rule type and configurable rule parameters.
/// TL approves criteria for their department before tasks can be created under them.
model KpiCriterion {
  id             String             @id @default(cuid())
  organizationId String             @default("default-org")
  name           String
  description    String?
  departmentId   String
  department     KpiDepartment      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  divisionId     String?
  division       KpiDepartment?     @relation("KpiCriterionDivision", fields: [divisionId], references: [id], onDelete: SetNull)
  weightage      Float
  ruleType       KpiRuleType
  ruleConfig     Json
  status         KpiCriterionStatus @default(ACTIVE)
  approvalStatus KpiApprovalStatus  @default(PENDING)
  createdById    String
  createdBy      User               @relation("KpiCriterionCreatedBy", fields: [createdById], references: [id])
  approvedById   String?
  approvedBy     User?              @relation("KpiCriterionApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tasks KpiTask[]

  @@index([departmentId, status, approvalStatus])
  @@index([organizationId, status, approvalStatus])
  @@index([divisionId])
}

/// TL-created task instance under an approved KpiCriterion for one employee in one monthly review.
model KpiTask {
  id                  String        @id @default(cuid())
  organizationId      String        @default("default-org")
  name                String
  description         String?
  criterionId         String
  criterion           KpiCriterion  @relation(fields: [criterionId], references: [id], onDelete: Restrict)
  reviewId            String
  review              KpiReview     @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  assignedToId        String
  assignedTo          User          @relation("KpiTaskAssignedTo", fields: [assignedToId], references: [id])
  assignedById        String
  assignedBy          User          @relation("KpiTaskAssignedBy", fields: [assignedById], references: [id])
  taskType            KpiTaskType   @default(ONE_TIME)
  assignedDate        DateTime      @default(now())
  dueDate             DateTime?
  requiresFileUpload  Boolean       @default(false)
  status              KpiTaskStatus @default(ASSIGNED)
  isPartialCompletion Boolean       @default(false)
  systemRating        Float?
  finalRating         Float?
  ratingExplanation   String?
  fileUrl             String?
  employeeRemarks     String?
  tlRemarks           String?
  timerElapsedMinutes Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  events KpiTaskEvent[]

  @@index([criterionId])
  @@index([organizationId, status])
  @@index([reviewId, status])
  @@index([assignedToId, status])
}

/// Audit trail for every status change on a KpiTask.
model KpiTaskEvent {
  id        String           @id @default(cuid())
  organizationId String      @default("default-org")
  taskId    String
  task      KpiTask          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User             @relation("KpiTaskEventActor", fields: [actorId], references: [id])
  actorRole String
  eventType KpiTaskEventType
  oldStatus String?
  newStatus String?
  timestamp DateTime         @default(now())
  reason    String?
  metadata  Json?

  @@index([taskId, timestamp])
  @@index([organizationId, timestamp])
}

/// Singleton record for admin-configured working hours, breaks, and holidays.
/// id is always "default".
model WorkingCalendar {
  id            String   @id @default("default")
  organizationId String  @default("default-org")
  workStartTime String   @default("10:00")
  workEndTime   String   @default("17:30")
  timezone      String   @default("Asia/Kolkata")
  graceMinutes  Int      @default(30)
  /// int[] — day-of-week indices (0=Sun … 6=Sat); default Mon–Sat [1,2,3,4,5,6]
  workingDays   Json
  /// {start: string, end: string}[] — 24 h "HH:MM" pairs
  breaks        Json
  /// ISO date strings for public holidays
  holidays      Json
  updatedAt     DateTime @updatedAt
  updatedById   String?
  updatedBy     User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// OT & COMP-OFF MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum OtApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HolidayType {
  NATIONAL
  COMPANY
  RESTRICTED
  WEEKEND
}

enum OtDayType {
  WORKING_DAY
  HOLIDAY
  WEEKEND
}

/// Singleton config for OT module (id = "default").
/// Stores standard hours/day, OT rate per hour, and comp-off slab breakpoints.
model OtSettings {
  id                 String   @id @default("default")
  organizationId     String   @default("default-org")
  standardHoursPerDay Decimal @default(8) @db.Decimal(4, 2)
  otRatePerHour      Decimal  @default(100) @db.Decimal(10, 2)
  /// JSON: [{minHours: number, compOffDays: number}] sorted ascending
  compOffSlabs       Json
  requiresWorkReport Boolean  @default(false)
  graceMinutes       Int      @default(15)
  updatedAt          DateTime @updatedAt
  updatedById        String?

  @@index([organizationId])
}

/// Company + public holiday calendar used for OT/comp-off eligibility checks.
model Holiday {
  id          String      @id @default(cuid())
  organizationId String   @default("default-org")
  holidayDate DateTime    @db.Date
  holidayName String
  holidayType HolidayType
  createdAt   DateTime    @default(now())

  @@unique([organizationId, holidayDate, holidayType])
  @@index([holidayDate])
  @@index([organizationId, holidayDate])
}

/// Raw biometric attendance import record per employee per date.
model AttendanceLog {
  id                   String   @id @default(cuid())
  organizationId       String   @default("default-org")
  employeeId           String
  employee             User     @relation("AttendanceLogs", fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceDate       DateTime @db.Date
  checkIn              DateTime?
  checkOut             DateTime?
  totalHours           Decimal? @db.Decimal(5, 2)
  regularizationStatus String?
  approvalStatus       String   @default("Approved")
  remarks              String?
  earlyLeavingMins     Int      @default(0)
  permissionMins       Int      @default(0)
  workReportSubmitted  Boolean  @default(false)
  createdAt            DateTime @default(now())

  ot EmployeeOt?

  @@unique([organizationId, employeeId, attendanceDate])
  @@index([attendanceDate])
  @@index([organizationId, attendanceDate])
  @@index([employeeId, attendanceDate])
}

/// Calculated OT / Comp-Off record per employee per attendance date.
model EmployeeOt {
  id               String          @id @default(cuid())
  organizationId   String          @default("default-org")
  attendanceLogId  String          @unique
  attendanceLog    AttendanceLog   @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         User            @relation("EmployeeOtRecords", fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceDate   DateTime        @db.Date
  dayType          OtDayType       @default(WORKING_DAY)
  hoursWorked      Decimal         @db.Decimal(5, 2)
  otHours          Decimal         @default(0) @db.Decimal(5, 2)
  otRatePerHour    Decimal         @default(0) @db.Decimal(10, 2)
  otAmount         Decimal         @default(0) @db.Decimal(10, 2)
  compOffDays      Decimal         @default(0) @db.Decimal(4, 2)
  earlyLeavingMins Int             @default(0)
  regularizedPenaltyMins Int       @default(0)
  adjustedOtMins   Int             @default(0)
  permissionMins   Int             @default(0)
  approvalStatus   OtApprovalStatus @default(PENDING)
  tlApprovalStatus OtApprovalStatus @default(PENDING)
  managerApprovalStatus OtApprovalStatus @default(PENDING)
  hrApprovalStatus OtApprovalStatus @default(PENDING)
  approvedById     String?
  approvedBy       User?           @relation("OtApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  rejectionRemarks String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([employeeId, attendanceDate])
  @@index([organizationId, attendanceDate])
  @@index([approvalStatus])
  @@index([attendanceDate])
}

/// LOP (Loss of Pay) days per employee per payroll month.
model EmployeeLop {
  id           String   @id @default(cuid())
  organizationId String @default("default-org")
  employeeId   String
  employee     User     @relation("EmployeeLopRecords", fields: [employeeId], references: [id], onDelete: Cascade)
  payrollMonth DateTime @db.Date  // first day of month
  lopDays      Decimal  @db.Decimal(5, 2)
  remarks      String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([organizationId, employeeId, payrollMonth])
  @@index([payrollMonth])
  @@index([organizationId, payrollMonth])
}

// ─────────────────────────────────────────────────────────────────────────────
// HRMS MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum DocumentType {
  OFFER_LETTER
  ID_PROOF
  ONBOARDING
  CONTRACT
  OTHER
}

enum AudienceType {
  ORG
  DEPARTMENT
  DIVISION
}

enum LoanStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  REPAID
}

enum PolicyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PermissionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// HR policy document (handbook, SOPs, code of conduct, etc.)
model Policy {
  id             String       @id @default(cuid())
  organizationId String       @default("default-org")
  title          String
  category       String
  body           String       @db.Text
  version        Int          @default(1)
  status         PolicyStatus @default(DRAFT)
  effectiveFrom  DateTime?    @db.Date
  archivedAt     DateTime?
  createdById    String?
  createdBy      User?        @relation("PolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
}

/// Employee-linked documents (offer letters, IDs, onboarding files).
model EmployeeDocument {
  id           String       @id @default(cuid())
  organizationId String     @default("default-org")
  employeeId   String
  employee     User         @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: Cascade)
  type         DocumentType
  fileUrl      String
  issuedAt     DateTime?    @db.Date
  metadata     Json?
  createdAt    DateTime     @default(now())

  @@index([employeeId, type])
  @@index([organizationId])
}

/// Offer letter HTML template with variable token definitions.
model OfferLetterTemplate {
  id             String   @id @default(cuid())
  organizationId String   @default("default-org")
  name           String
  bodyHtml       String   @db.Text
  variables      Json
  createdById    String?
  createdBy      User?    @relation("OfferTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

/// Employee loan record.
model Loan {
  id             String     @id @default(cuid())
  organizationId String     @default("default-org")
  employeeId     String
  employee       User       @relation("EmployeeLoans", fields: [employeeId], references: [id], onDelete: Cascade)
  principal      Decimal    @db.Decimal(12, 2)
  interestRate   Decimal    @default(0) @db.Decimal(5, 2)
  tenureMonths   Int
  startMonth     DateTime   @db.Date
  status         LoanStatus @default(ACTIVE)
  remarks        String?
  approvedById   String?
  approvedBy     User?      @relation("LoanApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  repayments     LoanRepayment[]

  @@index([employeeId, status])
  @@index([organizationId])
}

/// Monthly loan repayment deduction.
model LoanRepayment {
  id           String   @id @default(cuid())
  loanId       String
  loan         Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payrollMonth DateTime @db.Date
  amount       Decimal  @db.Decimal(12, 2)
  paid         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([loanId, payrollMonth])
  @@index([payrollMonth])
}

/// Short-term salary advance request.
model Advance {
  id             String        @id @default(cuid())
  organizationId String        @default("default-org")
  employeeId     String
  employee       User          @relation("EmployeeAdvances", fields: [employeeId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  reason         String?
  status         AdvanceStatus @default(PENDING)
  approvedById   String?
  approvedBy     User?         @relation("AdvanceApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  repayFromMonth DateTime?     @db.Date
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([employeeId, status])
  @@index([organizationId])
}

/// Organisation/department/division announcement.
model Announcement {
  id             String       @id @default(cuid())
  organizationId String       @default("default-org")
  title          String
  body           String       @db.Text
  audience       AudienceType @default(ORG)
  targetId       String?
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdById    String?
  createdBy      User?        @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, audience])
  @@index([publishedAt])
}

/// Monthly Employee of the Month record.
model EmployeeOfMonth {
  id             String   @id @default(cuid())
  organizationId String   @default("default-org")
  month          DateTime @db.Date
  employeeId     String
  employee       User     @relation("EmployeeOfMonthWinners", fields: [employeeId], references: [id], onDelete: Cascade)
  citation       String?
  awardedById    String?
  awardedBy      User?    @relation("EmployeeOfMonthAwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@unique([organizationId, month])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTENDANCE EXPANSION — SHIFT & LEAVE
// ─────────────────────────────────────────────────────────────────────────────

/// Shift definition (e.g. Day, Night, General).
model Shift {
  id             String   @id @default(cuid())
  organizationId String   @default("default-org")
  name           String
  startTime      String
  endTime        String
  weeklyOff      Json
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments    EmployeeShift[]

  @@index([organizationId, active])
}

/// Employee shift assignment with effective date range.
model EmployeeShift {
  id            String    @id @default(cuid())
  employeeId    String
  employee      User      @relation("EmployeeShifts", fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId       String
  shift         Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  assignedById  String?
  assignedBy    User?     @relation("ShiftAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([employeeId, effectiveFrom])
}

/// Leave type master (Casual, Sick, Earned, etc.).
model LeaveType {
  id             String   @id @default(cuid())
  organizationId String   @default("default-org")
  code           String
  name           String
  paid           Boolean  @default(true)
  defaultQuota   Decimal  @default(0) @db.Decimal(5, 2)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  balances       LeaveBalance[]
  requests       LeaveRequest[]

  @@unique([organizationId, code])
  @@index([organizationId, active])
}

/// Annual leave balance ledger per employee per leave type.
model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  employee    User      @relation("EmployeeLeaveBalances", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year        Int
  opening     Decimal   @default(0) @db.Decimal(5, 2)
  accrued     Decimal   @default(0) @db.Decimal(5, 2)
  used        Decimal   @default(0) @db.Decimal(5, 2)
  balance     Decimal   @default(0) @db.Decimal(5, 2)
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId, year])
}

/// Employee leave application.
model LeaveRequest {
  id           String             @id @default(cuid())
  organizationId String           @default("default-org")
  employeeId   String
  employee     User               @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId  String
  leaveType    LeaveType          @relation(fields: [leaveTypeId], references: [id])
  fromDate     DateTime           @db.Date
  toDate       DateTime           @db.Date
  days         Decimal            @db.Decimal(5, 2)
  reason       String?
  status       LeaveRequestStatus @default(PENDING)
  approvedById String?
  approvedBy   User?              @relation("LeaveApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?
  remarks      String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([employeeId, status])
  @@index([organizationId, fromDate])
  @@index([fromDate])
}

/// Short permission slip (half-day / hour-level absence).
model PermissionRequest {
  id           String                 @id @default(cuid())
  organizationId String               @default("default-org")
  employeeId   String
  employee     User                   @relation("EmployeePermissionRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime               @db.Date
  fromTime     String
  toTime       String
  minutes      Int
  reason       String?
  status       PermissionRequestStatus @default(PENDING)
  approvedById String?
  approvedBy   User?                  @relation("PermissionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([employeeId, date])
  @@index([organizationId, date])
}

model WorkReport {
  id             String   @id @default(cuid())
  organizationId String   @default("default-org")
  userId         String
  user           User     @relation("EmployeeWorkReports", fields: [userId], references: [id], onDelete: Cascade)
  weekStart      DateTime
  summary        String
  accomplishments String?
  blockers       String?
  nextWeek       String?
  submittedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([organizationId, weekStart])
}
