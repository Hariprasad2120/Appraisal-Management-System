generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGEMENT
  MANAGER
  HR
  TL
  EMPLOYEE
  REVIEWER
  PARTNER
}

enum PlatformRole {
  PLATFORM_SUPER_ADMIN
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum AccountRole {
  ACCOUNT_OWNER
  ACCOUNT_ADMIN
}

enum AccountStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  ARCHIVED
}

enum AccountMembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum InviteScopeType {
  ACCOUNT
  ORGANIZATION
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum OrganizationRole {
  ORG_OWNER
  ORG_ADMIN
  MANAGEMENT
  HR
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  PARTNER_OR_DIRECTOR
  APPRAISAL_ADMIN
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum OrganizationUserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum OrganizationAccessStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum ReviewerRole {
  HR
  TL
  MANAGER
}

enum CycleType {
  INTERIM
  ANNUAL
  SPECIAL
}

enum CycleStatus {
  PENDING_SELF
  SELF_SUBMITTED
  AWAITING_AVAILABILITY
  RATING_IN_PROGRESS
  RATINGS_COMPLETE
  MANAGEMENT_REVIEW
  DATE_VOTING
  SCHEDULED
  DECIDED
  CLOSED
}

enum ReviewerAvailability {
  PENDING
  AVAILABLE
  NOT_AVAILABLE
}

enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SelfAssessmentStatus {
  DRAFT
  SUBMITTED
  REOPENED
  LOCKED
}

enum RatingEvaluation {
  ACCURATE
  OVERRATED
  UNDERRATED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ArrearStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

enum RescheduleStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum KpiReviewStatus {
  DRAFT
  FINALIZED
}

enum KpiItemKind {
  CRITERION
  TASK
}

enum KpiApprovalStatus {
  PENDING
  APPROVED
  DISAPPROVED
}

enum KpiTaskCompletionStatus {
  NOT_COMPLETED
  PARTIALLY_COMPLETED
  FULLY_COMPLETED
}

enum KpiRuleType {
  TURNAROUND_TIME
  DUE_DATE
  RECURRING_WEEKLY_DUE_DATE
  MANUAL
  HYBRID
}

enum KpiCriterionStatus {
  ACTIVE
  INACTIVE
}

enum KpiTaskType {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  RECURRING
  DUE_DATE_BASED
}

enum KpiTaskStatus {
  ASSIGNED
  IN_PROGRESS
  WAITING_REVIEW
  PAUSED
  PARTIALLY_COMPLETED
  CLOSED
  REOPENED
}

enum KpiTaskEventType {
  ASSIGNED
  STARTED
  PAUSE_REQUESTED
  PAUSE_APPROVED
  PAUSE_REJECTED
  PAUSED_BY_TL
  RESUMED
  SUBMITTED
  REOPENED
  PARTIALLY_COMPLETED
  CLOSED_BY_TL
  RATING_CALCULATED
  POINTS_CALCULATED
  ADMIN_OVERRIDE
}

model Account {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  status         AccountStatus @default(TRIAL)
  ownerUserId    String?
  ownerUser      User?         @relation("AccountOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organizations  Organization[]
  memberships    AccountMembership[]
  subscriptions  Subscription[]
  modules        AccountModule[]
  invites        Invite[]

  @@index([status, createdAt])
}

model Plan {
  id               String       @id @default(cuid())
  key              String       @unique
  name             String
  priceMonthly     Decimal?     @db.Decimal(12, 2)
  priceYearly      Decimal?     @db.Decimal(12, 2)
  priceDisplay     String?
  maxOrganizations Int?
  maxEmployees     Int?
  allowedModules   Json?
  features         Json?
  status           PlanStatus   @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  subscriptions    Subscription[]
  accountModules   AccountModule[]
}

model Subscription {
  id         String             @id @default(cuid())
  accountId  String
  account    Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  planId     String
  plan       Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status     SubscriptionStatus @default(TRIAL)
  startedAt  DateTime?
  endsAt     DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([accountId, status])
  @@index([planId, status])
}

model AccountMembership {
  id          String                  @id @default(cuid())
  accountId   String
  account     Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId      String
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        AccountRole
  status      AccountMembershipStatus @default(ACTIVE)
  invitedById String?
  invitedBy   User?                   @relation("AccountMembershipInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([accountId, userId])
  @@index([userId, status])
  @@index([accountId, role, status])
}

model AccountModule {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  planId     String?
  plan       Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  enabled    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([accountId, moduleId])
  @@index([accountId, enabled])
}

model Invite {
  id              String          @id @default(cuid())
  scopeType       InviteScopeType
  accountId       String?
  account         Account?        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organizationId  String?
  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String
  emailNormalized String
  name            String?
  accountRole     AccountRole?
  organizationRole OrganizationRole?
  branchId        String?
  departmentId    String?
  teamLeadId      String?
  managerId       String?
  reviewerId      String?
  tokenHash       String          @unique
  status          InviteStatus    @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  invitedById     String?
  invitedBy       User?           @relation("InviteSentBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedUserId  String?
  acceptedUser    User?           @relation("InviteAcceptedUser", fields: [acceptedUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([emailNormalized, status])
  @@index([accountId, status])
  @@index([organizationId, status])
  @@index([scopeType, expiresAt])
}

model Organization {
  id             String             @id @default(cuid())
  accountId      String
  account        Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  slug           String             @unique
  name           String
  legalName      String?
  industry       String?
  logoUrl        String?
  primaryColor   String?
  address        String?
  contactEmail   String?
  contactPhone   String?
  status         OrganizationStatus @default(PENDING)
  explicitlyAllowsPlatformDataAccess Boolean @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  branches       Branch[]
  departments    Department[]
  divisions      Division[]
  designations   Designation[]
  memberships    OrganizationUser[]
  roleAssignments UserRoleAssignment[]
  reporting      ReportingHierarchy[]
  modules        OrganizationModule[]
  access         OrganizationAccess?
  settings       OrganizationSettings?
  invites        Invite[]

  @@index([accountId, status])
  @@index([status, createdAt])
}

model Branch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  address        String?
  city           String?
  state          String?
  country        String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  departments    Department[]
  memberships    OrganizationUser[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, active])
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name           String
  code           String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  divisions      Division[]
  designations   Designation[]
  memberships    OrganizationUser[]

  @@unique([organizationId, branchId, name])
  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@index([branchId])
}

model Division {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  name           String
  code           String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships    OrganizationUser[]

  @@unique([organizationId, departmentId, name])
  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@index([departmentId])
}

model Designation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  name           String
  code           String?
  level          Int?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships    OrganizationUser[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, active])
}

model OrganizationUser {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId       String?
  branch         Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  divisionId     String?
  division       Division?              @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  designationId  String?
  designation    Designation?           @relation(fields: [designationId], references: [id], onDelete: SetNull)
  status         OrganizationUserStatus @default(ACTIVE)
  joinedAt       DateTime               @default(now())
  invitedById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  roleAssignments UserRoleAssignment[]

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, status])
  @@index([branchId])
  @@index([departmentId])
}

model UserRoleAssignment {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipId   String?
  membership     OrganizationUser? @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role           OrganizationRole
  branchId       String?
  departmentId   String?
  createdAt      DateTime         @default(now())
  createdById    String?

  @@unique([organizationId, userId, role, branchId, departmentId])
  @@index([organizationId, role])
  @@index([userId, role])
  @@index([membershipId])
}

model ReportingHierarchy {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       User         @relation("HierarchyEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  teamLeadId     String?
  teamLead       User?        @relation("HierarchyTeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        User?        @relation("HierarchyManager", fields: [managerId], references: [id], onDelete: SetNull)
  managementId   String?
  management     User?        @relation("HierarchyManagement", fields: [managementId], references: [id], onDelete: SetNull)
  active         Boolean      @default(true)
  effectiveFrom  DateTime     @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, active])
  @@index([employeeId, active])
  @@index([teamLeadId])
  @@index([managerId])
  @@index([managementId])
}

model Module {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations OrganizationModule[]
  accountModules AccountModule[]
}

model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  enabled        Boolean      @default(false)
  enabledAt      DateTime?
  enabledById    String?
  disabledAt     DateTime?
  disabledById   String?
  settings       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, moduleId])
  @@index([organizationId, enabled])
}

model OrganizationAccess {
  id             String                   @id @default(cuid())
  organizationId String                   @unique
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         OrganizationAccessStatus @default(TRIAL)
  planName       String?
  seatsLimit     Int?
  startsAt       DateTime?
  renewsAt       DateTime?
  expiresAt      DateTime?
  suspendedAt    DateTime?
  notes          String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([status, expiresAt])
}

model OrganizationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timezone       String       @default("Asia/Kolkata")
  locale         String       @default("en-IN")
  dateFormat     String       @default("dd/MM/yyyy")
  appraisalSettings Json?
  branding       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailNormalized String @unique
  passwordHash  String
  passkeyHash   String?
  passkeySetupRequired Boolean @default(true)
  googleLoginAllowed   Boolean @default(false)
  name          String
  status        UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  role          Role
  secondaryRole Role?
  platformRole  PlatformRole?
  organizationId String @default("default-org")
  activeOrganizationId String?
  branchId      String?
  departmentId  String?
  divisionId    String?
  designationId String?
  teamLeadId    String?
  department    String?
  kpiDepartmentId String?
  kpiDepartment   KpiDepartment? @relation("UserKpiDepartment", fields: [kpiDepartmentId], references: [id], onDelete: SetNull)
  joiningDate   DateTime
  active        Boolean  @default(true)
  currentSalary Decimal? @db.Decimal(12, 2)

  employeeNumber     Int?      @unique
  firstName          String?
  lastName           String?
  location           String?
  fatherName         String?
  photo              String?
  designation        String?
  zohoRole           String?
  employmentType     String?
  employeeStatus     String?
  sourceOfHire       String?
  reportingManagerId String?
  reportingManager   User?     @relation("Reporting", fields: [reportingManagerId], references: [id])
  reports            User[]    @relation("Reporting")
  dob                DateTime?
  gender             String?
  maritalStatus      String?
  workPhone          String?
  personalPhone      String?
  personalEmail      String?
  presentAddress     String?
  permanentAddress   String?
  aadhaar            String?
  pan                String?
  uan                String?
  bankName           String?
  bankAccount        String?
  ifsc               String?
  accountType        String?
  stateCode          String?

  salary          EmployeeSalary?
  salaryRevisions SalaryRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cyclesAsEmployee  AppraisalCycle[]    @relation("EmpCycles")
  cyclesClaimed     AppraisalCycle[]    @relation("CycleClaimedBy")
  assignmentsMade   CycleAssignment[]   @relation("AssignedBy")
  assignments       CycleAssignment[]   @relation("Reviewer")
  ratings           Rating[]
  votes             DateVote[]
  decisionsMade     AppraisalDecision[] @relation("DecidedBy")
  notifications     Notification[]
  auditLogs         AuditLog[]
  securityEvents    SecurityEvent[]
  momsCreated        MOM[]               @relation("MomAuthor")
  extensionsRaised   ExtensionRequest[]  @relation("ExtRequester")
  extensionsDecided  ExtensionRequest[]  @relation("ExtDecider")
  criteriaOverrides    CriteriaOverride[]
  ratingReviews        RatingReview[]
  ratingDisagreements  RatingDisagreement[]
  ticketsRaised        Ticket[]           @relation("TicketRaiser")
  ticketsAssigned    Ticket[]           @relation("TicketAssignee")
  ticketComments     TicketComment[]
  userSessions       UserSession[]
  arrears            Arrear[]           @relation("ArrearEmployee")
  arrearApprovals    Arrear[]           @relation("ArrearApprover")
  reschedulesCreated MeetingReschedule[] @relation("RescheduledBy")
  reschedulesConfirmed MeetingReschedule[] @relation("RescheduleConfirmer")
  passwordResetTokens PasswordResetToken[]
  passkeyResetRequests PasskeyResetRequest[] @relation("PasskeyResetUser")
  passkeyResetDecisions PasskeyResetRequest[] @relation("PasskeyResetDecider")
  loginChallenges LoginChallenge[]
  messageRetriggers MessageRetriggerLog[] @relation("MessageRetriggerActor")
  messageRetriggerRecipients MessageRetriggerLog[] @relation("MessageRetriggerRecipient")
  kpiReviews KpiReview[] @relation("KpiReviewEmployee")
  kpiReviewsCreated KpiReview[] @relation("KpiReviewCreatedBy")
  kpiReviewsFinalized KpiReview[] @relation("KpiReviewFinalizedBy")
  kpiReviewItemsApproved KpiReviewItem[] @relation("KpiReviewItemApprovedBy")
  kpiCriteriaCreated KpiCriterion[] @relation("KpiCriterionCreatedBy")
  kpiCriteriaApproved KpiCriterion[] @relation("KpiCriterionApprovedBy")
  kpiTasksReceived KpiTask[] @relation("KpiTaskAssignedTo")
  kpiTasksAssigned KpiTask[] @relation("KpiTaskAssignedBy")
  kpiTaskEvents KpiTaskEvent[] @relation("KpiTaskEventActor")
  workingCalendarUpdates WorkingCalendar[]
  attendanceLogs         AttendanceLog[]  @relation("AttendanceLogs")
  employeeOtRecords      EmployeeOt[]     @relation("EmployeeOtRecords")
  otApprovals            EmployeeOt[]     @relation("OtApprovedBy")
  employeeLopRecords     EmployeeLop[]    @relation("EmployeeLopRecords")
  ownedAccounts          Account[]        @relation("AccountOwner")
  accountMemberships     AccountMembership[]
  accountMembershipInvites AccountMembership[] @relation("AccountMembershipInvitedBy")
  organizationMemberships OrganizationUser[]
  organizationRoles       UserRoleAssignment[]
  hierarchyAsEmployee     ReportingHierarchy[] @relation("HierarchyEmployee")
  hierarchyAsTeamLead     ReportingHierarchy[] @relation("HierarchyTeamLead")
  hierarchyAsManager      ReportingHierarchy[] @relation("HierarchyManager")
  hierarchyAsManagement   ReportingHierarchy[] @relation("HierarchyManagement")
  invitesSent            Invite[]         @relation("InviteSentBy")
  acceptedInvites        Invite[]         @relation("InviteAcceptedUser")

  // HRMS relations
  policiesCreated        Policy[]              @relation("PolicyCreatedBy")
  employeeDocuments      EmployeeDocument[]    @relation("EmployeeDocuments")
  offerTemplatesCreated  OfferLetterTemplate[] @relation("OfferTemplateCreatedBy")
  loans                  Loan[]               @relation("EmployeeLoans")
  loansApproved          Loan[]               @relation("LoanApprovedBy")
  advances               Advance[]            @relation("EmployeeAdvances")
  advancesApproved       Advance[]            @relation("AdvanceApprovedBy")
  announcementsCreated   Announcement[]       @relation("AnnouncementCreatedBy")
  employeeOfMonthWins    EmployeeOfMonth[]    @relation("EmployeeOfMonthWinners")
  employeeOfMonthAwarded EmployeeOfMonth[]    @relation("EmployeeOfMonthAwardedBy")

  // Attendance expansion relations
  employeeShifts         EmployeeShift[]      @relation("EmployeeShifts")
  shiftsAssigned         EmployeeShift[]      @relation("ShiftAssignedBy")
  leaveBalances          LeaveBalance[]       @relation("EmployeeLeaveBalances")
  leaveRequests          LeaveRequest[]       @relation("EmployeeLeaveRequests")
  leaveApprovals         LeaveRequest[]       @relation("LeaveApprovedBy")
  permissionRequests     PermissionRequest[]  @relation("EmployeePermissionRequests")
  permissionApprovals    PermissionRequest[]  @relation("PermissionApprovedBy")
  workReports            WorkReport[]         @relation("EmployeeWorkReports")

  @@index([role, active])
  @@index([status, active])
  @@index([organizationId, role, active])
  @@index([organizationId, employeeNumber])
  @@index([branchId])
  @@index([departmentId])
  @@index([teamLeadId])
  @@index([kpiDepartmentId])
}

model KpiDepartment {
  id        String   @id @default(cuid())
  organizationId String @default("default-org")
  name      String
  parentId  String?
  parent    KpiDepartment?  @relation("KpiDepartmentTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  KpiDepartment[] @relation("KpiDepartmentTree")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]        @relation("UserKpiDepartment")
  templates KpiTemplate[]
  reviews   KpiReview[]
  criteria  KpiCriterion[]
  criteriaAsDivision KpiCriterion[] @relation("KpiCriterionDivision")

  @@unique([organizationId, parentId, name])
  @@index([organizationId, active])
  @@index([parentId, active, sortOrder])
}

model KpiTemplate {
  id           String        @id @default(cuid())
  organizationId String      @default("default-org")
  departmentId String
  department   KpiDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  version      Int           @default(1)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  items   KpiTemplateItem[]
  reviews KpiReview[]

  @@index([departmentId, active])
  @@index([organizationId, active])
}

model KpiTemplateItem {
  id           String      @id @default(cuid())
  organizationId String    @default("default-org")
  templateId   String
  template     KpiTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parentItemId String?
  parentItem   KpiTemplateItem?  @relation("KpiTemplateItemTree", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItems   KpiTemplateItem[] @relation("KpiTemplateItemTree")
  itemKind     KpiItemKind @default(TASK)
  name         String
  weightage    Float
  measurement  String
  target       String
  description  String?
  active       Boolean     @default(true)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  reviewItems KpiReviewItem[]

  @@index([templateId, active, sortOrder])
  @@index([organizationId])
  @@index([parentItemId, sortOrder])
}

model KpiReview {
  id                       String          @id @default(cuid())
  organizationId           String          @default("default-org")
  userId                   String
  user                     User            @relation("KpiReviewEmployee", fields: [userId], references: [id], onDelete: Cascade)
  departmentId             String
  department               KpiDepartment   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  templateId               String
  template                 KpiTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  month                    DateTime
  status                   KpiReviewStatus @default(DRAFT)
  templateSnapshot         Json
  totalAchievementPercent  Float           @default(0)
  monthlyPointScore        Int             @default(0)
  averageRating            Float           @default(0)
  performanceCategory      String          @default("Poor Performer")
  overallRemarks           String?
  createdById              String
  createdBy                User            @relation("KpiReviewCreatedBy", fields: [createdById], references: [id])
  finalizedById            String?
  finalizedBy              User?           @relation("KpiReviewFinalizedBy", fields: [finalizedById], references: [id])
  finalizedAt              DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  items KpiReviewItem[]
  kpiTasks KpiTask[]

  @@unique([organizationId, userId, month])
  @@index([month, status])
  @@index([organizationId, month, status])
  @@index([departmentId, month])
}

model KpiReviewItem {
  id                    String           @id @default(cuid())
  organizationId        String           @default("default-org")
  reviewId              String
  review                KpiReview        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  templateItemId         String?
  templateItem           KpiTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)
  parentItemId           String?
  parentItem             KpiReviewItem?   @relation("KpiReviewItemTree", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItems             KpiReviewItem[]  @relation("KpiReviewItemTree")
  itemKind               KpiItemKind      @default(TASK)
  name                  String
  weightage             Float
  measurement           String
  target                String
  description           String?
  assignedToEmployee    Boolean          @default(false)
  completionStatus      KpiTaskCompletionStatus @default(NOT_COMPLETED)
  approvalStatus        KpiApprovalStatus @default(PENDING)
  approvalRemarks       String?
  approvedById          String?
  approvedBy            User?             @relation("KpiReviewItemApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt            DateTime?
  rating                Float?
  achievementPercent    Float            @default(0)
  actualAchievement     String?
  remarks               String?
  weightedAchievement   Float            @default(0)
  sortOrder             Int              @default(0)

  @@index([reviewId, sortOrder])
  @@index([organizationId])
  @@index([parentItemId, sortOrder])
  @@index([approvalStatus])
}

model EmployeeSalary {
  id             String   @id @default(cuid())
  organizationId String   @default("default-org")
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grossAnnum     Decimal  @default(0) @db.Decimal(12, 2)
  ctcAnnum       Decimal  @default(0) @db.Decimal(12, 2)
  basic          Decimal  @default(0) @db.Decimal(12, 2)
  hra            Decimal  @default(0) @db.Decimal(12, 2)
  conveyance     Decimal  @default(0) @db.Decimal(12, 2)
  transport      Decimal  @default(0) @db.Decimal(12, 2)
  travelling     Decimal  @default(0) @db.Decimal(12, 2)
  fixedAllowance Decimal  @default(0) @db.Decimal(12, 2)
  stipend        Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model SalaryRevision {
  id                  String   @id @default(cuid())
  organizationId      String   @default("default-org")
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status              String   // "Approved" | "Pending" | "Rejected"
  grossAnnum          Decimal  @db.Decimal(12, 2)
  ctcAnnum            Decimal  @db.Decimal(12, 2)
  revisedCtc          Decimal  @db.Decimal(12, 2)
  isCTCChangedByPerc  Boolean  @default(false)
  revisionPercentage  Decimal? @db.Decimal(6, 2)
  effectiveFrom       DateTime
  payoutMonth         DateTime
  basic               Decimal  @default(0) @db.Decimal(12, 2)
  hra                 Decimal  @default(0) @db.Decimal(12, 2)
  conveyance          Decimal  @default(0) @db.Decimal(12, 2)
  transport           Decimal  @default(0) @db.Decimal(12, 2)
  travelling          Decimal  @default(0) @db.Decimal(12, 2)
  fixedAllowance      Decimal  @default(0) @db.Decimal(12, 2)
  stipend             Decimal  @default(0) @db.Decimal(12, 2)
  createdAt           DateTime @default(now())

  @@index([userId, effectiveFrom])
  @@index([organizationId, effectiveFrom])
