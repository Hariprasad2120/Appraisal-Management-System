generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGEMENT
  MANAGER
  HR
  TL
  EMPLOYEE
  REVIEWER
  PARTNER
}

enum ReviewerRole {
  HR
  TL
  MANAGER
}

enum CycleType {
  INTERIM
  ANNUAL
  SPECIAL
}

enum CycleStatus {
  PENDING_SELF
  SELF_SUBMITTED
  AWAITING_AVAILABILITY
  RATING_IN_PROGRESS
  RATINGS_COMPLETE
  MANAGEMENT_REVIEW
  DATE_VOTING
  SCHEDULED
  DECIDED
  CLOSED
}

enum ReviewerAvailability {
  PENDING
  AVAILABLE
  NOT_AVAILABLE
}

enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SelfAssessmentStatus {
  DRAFT
  SUBMITTED
  REOPENED
  LOCKED
}

enum RatingEvaluation {
  ACCURATE
  OVERRATED
  UNDERRATED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ArrearStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

enum RescheduleStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum KpiReviewStatus {
  DRAFT
  FINALIZED
}

enum KpiItemKind {
  CRITERION
  TASK
}

enum KpiApprovalStatus {
  PENDING
  APPROVED
  DISAPPROVED
}

enum KpiTaskCompletionStatus {
  NOT_COMPLETED
  PARTIALLY_COMPLETED
  FULLY_COMPLETED
}

enum KpiRuleType {
  TURNAROUND_TIME
  DUE_DATE
  RECURRING_WEEKLY_DUE_DATE
  MANUAL
  HYBRID
}

enum KpiCriterionStatus {
  ACTIVE
  INACTIVE
}

enum KpiTaskType {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  RECURRING
  DUE_DATE_BASED
}

enum KpiTaskStatus {
  ASSIGNED
  IN_PROGRESS
  WAITING_REVIEW
  PAUSED
  PARTIALLY_COMPLETED
  CLOSED
  REOPENED
}

enum KpiTaskEventType {
  ASSIGNED
  STARTED
  PAUSE_REQUESTED
  PAUSE_APPROVED
  PAUSE_REJECTED
  PAUSED_BY_TL
  RESUMED
  SUBMITTED
  REOPENED
  PARTIALLY_COMPLETED
  CLOSED_BY_TL
  RATING_CALCULATED
  POINTS_CALCULATED
  ADMIN_OVERRIDE
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  passkeyHash   String?
  passkeySetupRequired Boolean @default(true)
  googleLoginAllowed   Boolean @default(false)
  name          String
  role          Role
  secondaryRole Role?
  department    String?
  kpiDepartmentId String?
  kpiDepartment   KpiDepartment? @relation("UserKpiDepartment", fields: [kpiDepartmentId], references: [id], onDelete: SetNull)
  joiningDate   DateTime
  active        Boolean  @default(true)
  currentSalary Decimal? @db.Decimal(12, 2)

  employeeNumber     Int?      @unique
  firstName          String?
  lastName           String?
  location           String?
  fatherName         String?
  photo              String?
  designation        String?
  zohoRole           String?
  employmentType     String?
  employeeStatus     String?
  sourceOfHire       String?
  reportingManagerId String?
  reportingManager   User?     @relation("Reporting", fields: [reportingManagerId], references: [id])
  reports            User[]    @relation("Reporting")
  dob                DateTime?
  gender             String?
  maritalStatus      String?
  workPhone          String?
  personalPhone      String?
  personalEmail      String?
  presentAddress     String?
  permanentAddress   String?
  aadhaar            String?
  pan                String?
  uan                String?
  bankName           String?
  bankAccount        String?
  ifsc               String?
  accountType        String?
  stateCode          String?

  salary          EmployeeSalary?
  salaryRevisions SalaryRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cyclesAsEmployee  AppraisalCycle[]    @relation("EmpCycles")
  cyclesClaimed     AppraisalCycle[]    @relation("CycleClaimedBy")
  assignmentsMade   CycleAssignment[]   @relation("AssignedBy")
  assignments       CycleAssignment[]   @relation("Reviewer")
  ratings           Rating[]
  votes             DateVote[]
  decisionsMade     AppraisalDecision[] @relation("DecidedBy")
  notifications     Notification[]
  auditLogs         AuditLog[]
  securityEvents    SecurityEvent[]
  momsCreated        MOM[]               @relation("MomAuthor")
  extensionsRaised   ExtensionRequest[]  @relation("ExtRequester")
  extensionsDecided  ExtensionRequest[]  @relation("ExtDecider")
  criteriaOverrides    CriteriaOverride[]
  ratingReviews        RatingReview[]
  ratingDisagreements  RatingDisagreement[]
  ticketsRaised        Ticket[]           @relation("TicketRaiser")
  ticketsAssigned    Ticket[]           @relation("TicketAssignee")
  ticketComments     TicketComment[]
  userSessions       UserSession[]
  arrears            Arrear[]           @relation("ArrearEmployee")
  arrearApprovals    Arrear[]           @relation("ArrearApprover")
  reschedulesCreated MeetingReschedule[] @relation("RescheduledBy")
  reschedulesConfirmed MeetingReschedule[] @relation("RescheduleConfirmer")
  passwordResetTokens PasswordResetToken[]
  passkeyResetRequests PasskeyResetRequest[] @relation("PasskeyResetUser")
  passkeyResetDecisions PasskeyResetRequest[] @relation("PasskeyResetDecider")
  loginChallenges LoginChallenge[]
  messageRetriggers MessageRetriggerLog[] @relation("MessageRetriggerActor")
  messageRetriggerRecipients MessageRetriggerLog[] @relation("MessageRetriggerRecipient")
  kpiReviews KpiReview[] @relation("KpiReviewEmployee")
  kpiReviewsCreated KpiReview[] @relation("KpiReviewCreatedBy")
  kpiReviewsFinalized KpiReview[] @relation("KpiReviewFinalizedBy")
  kpiReviewItemsApproved KpiReviewItem[] @relation("KpiReviewItemApprovedBy")
  kpiCriteriaCreated KpiCriterion[] @relation("KpiCriterionCreatedBy")
  kpiCriteriaApproved KpiCriterion[] @relation("KpiCriterionApprovedBy")
  kpiTasksReceived KpiTask[] @relation("KpiTaskAssignedTo")
  kpiTasksAssigned KpiTask[] @relation("KpiTaskAssignedBy")
  kpiTaskEvents KpiTaskEvent[] @relation("KpiTaskEventActor")
  workingCalendarUpdates WorkingCalendar[]
  attendanceLogs         AttendanceLog[]  @relation("AttendanceLogs")
  employeeOtRecords      EmployeeOt[]     @relation("EmployeeOtRecords")
  otApprovals            EmployeeOt[]     @relation("OtApprovedBy")
  employeeLopRecords     EmployeeLop[]    @relation("EmployeeLopRecords")

  @@index([role, active])
  @@index([kpiDepartmentId])
}

model KpiDepartment {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    KpiDepartment?  @relation("KpiDepartmentTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  KpiDepartment[] @relation("KpiDepartmentTree")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]        @relation("UserKpiDepartment")
  templates KpiTemplate[]
  reviews   KpiReview[]
  criteria  KpiCriterion[]
  criteriaAsDivision KpiCriterion[] @relation("KpiCriterionDivision")

  @@unique([parentId, name])
  @@index([parentId, active, sortOrder])
}

model KpiTemplate {
  id           String        @id @default(cuid())
  departmentId String
  department   KpiDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  version      Int           @default(1)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  items   KpiTemplateItem[]
  reviews KpiReview[]

  @@index([departmentId, active])
}

model KpiTemplateItem {
  id           String      @id @default(cuid())
  templateId   String
  template     KpiTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parentItemId String?
  parentItem   KpiTemplateItem?  @relation("KpiTemplateItemTree", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItems   KpiTemplateItem[] @relation("KpiTemplateItemTree")
  itemKind     KpiItemKind @default(TASK)
  name         String
  weightage    Float
  measurement  String
  target       String
  description  String?
  active       Boolean     @default(true)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  reviewItems KpiReviewItem[]

  @@index([templateId, active, sortOrder])
  @@index([parentItemId, sortOrder])
}

model KpiReview {
  id                       String          @id @default(cuid())
  userId                   String
  user                     User            @relation("KpiReviewEmployee", fields: [userId], references: [id], onDelete: Cascade)
  departmentId             String
  department               KpiDepartment   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  templateId               String
  template                 KpiTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  month                    DateTime
  status                   KpiReviewStatus @default(DRAFT)
  templateSnapshot         Json
  totalAchievementPercent  Float           @default(0)
  monthlyPointScore        Int             @default(0)
  averageRating            Float           @default(0)
  performanceCategory      String          @default("Poor Performer")
  overallRemarks           String?
  createdById              String
  createdBy                User            @relation("KpiReviewCreatedBy", fields: [createdById], references: [id])
  finalizedById            String?
  finalizedBy              User?           @relation("KpiReviewFinalizedBy", fields: [finalizedById], references: [id])
  finalizedAt              DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  items KpiReviewItem[]
  kpiTasks KpiTask[]

  @@unique([userId, month])
  @@index([month, status])
  @@index([departmentId, month])
}

model KpiReviewItem {
  id                    String           @id @default(cuid())
  reviewId              String
  review                KpiReview        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  templateItemId         String?
  templateItem           KpiTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)
  parentItemId           String?
  parentItem             KpiReviewItem?   @relation("KpiReviewItemTree", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItems             KpiReviewItem[]  @relation("KpiReviewItemTree")
  itemKind               KpiItemKind      @default(TASK)
  name                  String
  weightage             Float
  measurement           String
  target                String
  description           String?
  assignedToEmployee    Boolean          @default(false)
  completionStatus      KpiTaskCompletionStatus @default(NOT_COMPLETED)
  approvalStatus        KpiApprovalStatus @default(PENDING)
  approvalRemarks       String?
  approvedById          String?
  approvedBy            User?             @relation("KpiReviewItemApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt            DateTime?
  rating                Float?
  achievementPercent    Float            @default(0)
  actualAchievement     String?
  remarks               String?
  weightedAchievement   Float            @default(0)
  sortOrder             Int              @default(0)

  @@index([reviewId, sortOrder])
  @@index([parentItemId, sortOrder])
  @@index([approvalStatus])
}

model EmployeeSalary {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grossAnnum     Decimal  @default(0) @db.Decimal(12, 2)
  ctcAnnum       Decimal  @default(0) @db.Decimal(12, 2)
  basic          Decimal  @default(0) @db.Decimal(12, 2)
  hra            Decimal  @default(0) @db.Decimal(12, 2)
  conveyance     Decimal  @default(0) @db.Decimal(12, 2)
  transport      Decimal  @default(0) @db.Decimal(12, 2)
  travelling     Decimal  @default(0) @db.Decimal(12, 2)
  fixedAllowance Decimal  @default(0) @db.Decimal(12, 2)
  stipend        Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt      DateTime @updatedAt
}

model SalaryRevision {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status              String   // "Approved" | "Pending" | "Rejected"
  grossAnnum          Decimal  @db.Decimal(12, 2)
  ctcAnnum            Decimal  @db.Decimal(12, 2)
  revisedCtc          Decimal  @db.Decimal(12, 2)
  isCTCChangedByPerc  Boolean  @default(false)
  revisionPercentage  Decimal? @db.Decimal(6, 2)
  effectiveFrom       DateTime
  payoutMonth         DateTime
  basic               Decimal  @default(0) @db.Decimal(12, 2)
  hra                 Decimal  @default(0) @db.Decimal(12, 2)
  conveyance          Decimal  @default(0) @db.Decimal(12, 2)
  transport           Decimal  @default(0) @db.Decimal(12, 2)
  travelling          Decimal  @default(0) @db.Decimal(12, 2)
  fixedAllowance      Decimal  @default(0) @db.Decimal(12, 2)
  stipend             Decimal  @default(0) @db.Decimal(12, 2)
  createdAt           DateTime @default(now())

  @@index([userId, effectiveFrom])
}

model AppraisalCycle {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation("EmpCycles", fields: [userId], references: [id])
  type             CycleType
  startDate        DateTime
  status           CycleStatus @default(PENDING_SELF)
  scheduledDate    DateTime?
  tentativeDate1   DateTime?
  tentativeDate2   DateTime?
  isManagerCycle   Boolean     @default(false)
  ratingDeadline   DateTime?
  claimedById      String?
  claimedBy        User?       @relation("CycleClaimedBy", fields: [claimedById], references: [id])
  claimedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  self          SelfAssessment?
  assignments   CycleAssignment[]
  ratings       Rating[]
  decision      AppraisalDecision?
  extensions    ExtensionRequest[]
  auditLogs     AuditLog[]
  votes         DateVote[]
  moms                MOM[]
  ratingReviews       RatingReview[]
  ratingDisagreements RatingDisagreement[]
  arrear              Arrear?
  reschedules         MeetingReschedule[]

  @@index([userId, status])
  @@index([startDate])
  @@index([status, claimedById])
}

model SelfAssessment {
  id             String                 @id @default(cuid())
  cycleId        String                 @unique
  cycle          AppraisalCycle         @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  answers        Json
  submittedAt    DateTime?
  lastModifiedAt DateTime?
  editableUntil  DateTime
  locked         Boolean                @default(false)
  editCount      Int                    @default(0)
  status         SelfAssessmentStatus   @default(DRAFT)
}

model CycleAssignment {
  id                      String               @id @default(cuid())
  cycleId                 String
  cycle                   AppraisalCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId              String
  reviewer                User                 @relation("Reviewer", fields: [reviewerId], references: [id])
  role                    ReviewerRole
  availability            ReviewerAvailability @default(PENDING)
  availabilitySubmittedAt DateTime?
  assignedAt              DateTime             @default(now())
  assignedById            String
  assignedBy              User                 @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([cycleId, role])
  @@index([reviewerId])
}

model Rating {
  id           String         @id @default(cuid())
  cycleId      String
  cycle        AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User           @relation(fields: [reviewerId], references: [id])
  role         ReviewerRole
  scores           Json
  averageScore     Float
  comments         String
  postComment      String?
  submittedAt      DateTime       @default(now())
  locked           Boolean        @default(true)

  ratingReviews      RatingReview[]
  disagreement       RatingDisagreement?

  @@unique([cycleId, role])
  @@index([reviewerId])
}

model DateVote {
  id        String         @id @default(cuid())
  cycleId   String
  cycle     AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  voterId   String
  voter     User           @relation(fields: [voterId], references: [id])
  date      DateTime
  createdAt DateTime       @default(now())

  @@unique([cycleId, voterId])
  @@index([cycleId, date])
}

model MOM {
  id        String         @id @default(cuid())
  cycleId   String
  cycle     AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  /// Role perspective that owns this record: "ADMIN" | "MANAGEMENT" | "HR"
  role      String         @default("MANAGEMENT")
  content   String
  authorId  String
  author    User           @relation("MomAuthor", fields: [authorId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cycleId, role])
  @@index([cycleId])
}

model AppraisalDecision {
  id                String         @id @default(cuid())
  cycleId           String         @unique
  cycle             AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  averagedRating    Float?
  finalRating       Float
  slabId            String?
  slab              IncrementSlab? @relation(fields: [slabId], references: [id])
  suggestedAmount   Decimal        @db.Decimal(12, 2)
  finalAmount       Decimal        @db.Decimal(12, 2)
  comments          String?
  managementScores  Json?
  managementComment String?
  decidedById       String
  decidedBy         User           @relation("DecidedBy", fields: [decidedById], references: [id])
  decidedAt         DateTime       @default(now())
}

model IncrementSlab {
  id          String  @id @default(cuid())
  label       String
  grade       String  @default("")
  minRating   Float
  maxRating   Float
  salaryTier  String  @default("ALL")
  hikePercent Float

  decisions AppraisalDecision[]

  @@index([minRating, maxRating])
}

model ExtensionRequest {
  id            String          @id @default(cuid())
  cycleId       String
  cycle         AppraisalCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  requesterId   String
  requester     User            @relation("ExtRequester", fields: [requesterId], references: [id])
  reason        String
  status        ExtensionStatus @default(PENDING)
  extendedUntil DateTime?
  decidedById   String?
  decidedBy     User?           @relation("ExtDecider", fields: [decidedById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Notification {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  type           String
  message        String
  link           String?
  read           Boolean   @default(false)
  persistent     Boolean   @default(false)
  critical       Boolean   @default(false)
  dismissed      Boolean   @default(false)
  /// User clicked "Acknowledge" (distinct from dismiss/close)
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  /// Admin marked this as important — ignored ones can be re-triggered
  important      Boolean   @default(false)
  /// Marks a re-triggered urgent copy; persists until acknowledged
  urgent         Boolean   @default(false)
  /// Id of the original notification this was re-triggered from
  retriggeredFromId String?
  createdAt      DateTime  @default(now())
  retriggerLogs  MessageRetriggerLog[]

  @@index([userId, read])
  @@index([userId, dismissed])
  @@index([userId, critical, dismissed])
}

model LoginChallenge {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   @default("credentials")
  redirectTo String  @default("/")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model PasskeyResetRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("PasskeyResetUser", fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING")
  requestedAt DateTime @default(now())
  decidedAt   DateTime?
  decidedById String?
  decidedBy   User?    @relation("PasskeyResetDecider", fields: [decidedById], references: [id])
  reason      String?

  @@index([status, requestedAt])
  @@index([userId, status])
}

model MessageRetriggerLog {
  id             String   @id @default(cuid())
  actorId        String
  actor          User     @relation("MessageRetriggerActor", fields: [actorId], references: [id])
  recipientId    String
  recipient      User     @relation("MessageRetriggerRecipient", fields: [recipientId], references: [id])
  notificationId String?
  notification   Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  messageType    String
  channel        String
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([recipientId, createdAt])
}

model AuditLog {
  id        String          @id @default(cuid())
  cycleId   String?
  cycle     AppraisalCycle? @relation(fields: [cycleId], references: [id])
  actorId   String
  actor     User            @relation(fields: [actorId], references: [id])
  action    String
  before    Json?
  after     Json?
  createdAt DateTime        @default(now())

  @@index([cycleId, createdAt])
}

/// Security and access trail for login attempts plus session lifecycle events.
/// userId is nullable so failed login attempts for unknown/inactive users remain traceable.
model SecurityEvent {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String?
  event        String
  outcome      String
  ipAddress    String?
  userAgent    String?
  sessionToken String?
  details      Json?
  createdAt    DateTime @default(now())

  @@index([event, outcome, createdAt])
  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([sessionToken, createdAt])
}

/// Tracks each authenticated user session for admin monitoring.
model UserSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JWT session token identifier (sub claim or random token)
  token       String    @unique
  loginAt     DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  logoutAt    DateTime?
  /// "ACTIVE" | "TIMED_OUT" | "LOGGED_OUT"
  status      String    @default("ACTIVE")
  ipAddress   String?
  userAgent   String?
  /// Rough location from IP
  location    String?

  @@index([userId, status])
  @@index([status, lastSeenAt])
}

/// Admin-configurable key/value settings store.
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedById String?
}

/// Admin-editable override for criteria category questions.
/// categoryName must match a CRITERIA_CATEGORIES[].name entry.
/// questions replaces that category's default question list.
model CriteriaOverride {
  id           String   @id @default(cuid())
  categoryName String   @unique
  questions    Json     // string[]
  maxPoints    Int?     // override default maxPoints; null = use default
  updatedAt    DateTime @updatedAt
  updatedById  String
  updatedBy    User     @relation(fields: [updatedById], references: [id])
}

model Ticket {
  id          String         @id @default(cuid())
  raisedById  String
  raisedBy    User           @relation("TicketRaiser", fields: [raisedById], references: [id])
  assigneeId  String?
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  title       String
  description String
  category    String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  cycleId     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  comments    TicketComment[]

  @@index([raisedById, status])
  @@index([status, createdAt])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

/// Arrear record for a cycle — computed when meeting is late (>7 days after self-assessment submitted).
/// Locked once approved by management.
model Arrear {
  id            String        @id @default(cuid())
  cycleId       String        @unique
  cycle         AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation("ArrearEmployee", fields: [userId], references: [id])

  /// Days from (selfSubmittedAt + 7) to scheduledDate
  arrearDays    Int
  /// Daily rate = finalAmount / 365
  dailyRate     Decimal       @db.Decimal(12, 2)
  /// arrearDays * dailyRate
  arrearAmount  Decimal       @db.Decimal(12, 2)
  /// Date from which arrear is counted (selfSubmittedAt + 7 days)
  periodFrom    DateTime
  /// Date until which arrear is counted (scheduledDate)
  periodTo      DateTime
  /// Month in which arrears will be credited (set on approval)
  payoutMonth   DateTime?

  status        ArrearStatus  @default(PENDING_APPROVAL)
  approvedById  String?
  approvedBy    User?         @relation("ArrearApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  rejectedReason String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, status])
  @@index([cycleId])
}

/// Reschedule record when a meeting does not occur on the scheduled date.
model MeetingReschedule {
  id             String           @id @default(cuid())
  cycleId        String
  cycle          AppraisalCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  /// Original date that was missed
  originalDate   DateTime
  /// New proposed date
  newDate        DateTime
  reason         String
  rescheduledById String
  rescheduledBy  User             @relation("RescheduledBy", fields: [rescheduledById], references: [id])
  status         RescheduleStatus @default(PENDING)

  confirmedById  String?
  confirmedBy    User?            @relation("RescheduleConfirmer", fields: [confirmedById], references: [id])
  confirmedAt    DateTime?

  createdAt      DateTime         @default(now())

  @@index([cycleId, createdAt])
}

/// Reviewer evaluation of their own submitted rating (Accurate/Overrated/Underrated).
/// Defines negotiation ceiling for management.
model RatingDisagreement {
  id             String          @id @default(cuid())
  ratingId       String          @unique
  rating         Rating          @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  cycleId        String
  cycle          AppraisalCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId     String
  reviewer       User            @relation(fields: [reviewerId], references: [id])
  evaluation     RatingEvaluation
  comment        String?         // mandatory when OVERRATED or UNDERRATED
  // Optional revised scores per criteria (JSON: {criteriaName: score})
  revisedScores  Json?
  // Negotiation ceiling (computed or manually set)
  ceilingMin     Decimal?        @db.Decimal(12, 2)
  ceilingMax     Decimal?        @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([cycleId])
}

/// Post-comment review layer — reviewer can submit a revised rating per criterion
/// without overwriting the original Rating record.
model RatingReview {
  id           String   @id @default(cuid())
  ratingId     String
  rating       Rating   @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  cycleId      String
  cycle        AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User     @relation(fields: [reviewerId], references: [id])
  criteriaName String
  originalScore Float
  revisedScore  Float
  justification String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ratingId, criteriaName])
  @@index([cycleId])
}

/// Admin-created KPI criterion with a rule type and configurable rule parameters.
/// TL approves criteria for their department before tasks can be created under them.
model KpiCriterion {
  id             String             @id @default(cuid())
  name           String
  description    String?
  departmentId   String
  department     KpiDepartment      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  divisionId     String?
  division       KpiDepartment?     @relation("KpiCriterionDivision", fields: [divisionId], references: [id], onDelete: SetNull)
  weightage      Float
  ruleType       KpiRuleType
  ruleConfig     Json
  status         KpiCriterionStatus @default(ACTIVE)
  approvalStatus KpiApprovalStatus  @default(PENDING)
  createdById    String
  createdBy      User               @relation("KpiCriterionCreatedBy", fields: [createdById], references: [id])
  approvedById   String?
  approvedBy     User?              @relation("KpiCriterionApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tasks KpiTask[]

  @@index([departmentId, status, approvalStatus])
  @@index([divisionId])
}

/// TL-created task instance under an approved KpiCriterion for one employee in one monthly review.
model KpiTask {
  id                  String        @id @default(cuid())
  name                String
  description         String?
  criterionId         String
  criterion           KpiCriterion  @relation(fields: [criterionId], references: [id], onDelete: Restrict)
  reviewId            String
  review              KpiReview     @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  assignedToId        String
  assignedTo          User          @relation("KpiTaskAssignedTo", fields: [assignedToId], references: [id])
  assignedById        String
  assignedBy          User          @relation("KpiTaskAssignedBy", fields: [assignedById], references: [id])
  taskType            KpiTaskType   @default(ONE_TIME)
  assignedDate        DateTime      @default(now())
  dueDate             DateTime?
  requiresFileUpload  Boolean       @default(false)
  status              KpiTaskStatus @default(ASSIGNED)
  isPartialCompletion Boolean       @default(false)
  systemRating        Float?
  finalRating         Float?
  ratingExplanation   String?
  fileUrl             String?
  employeeRemarks     String?
  tlRemarks           String?
  timerElapsedMinutes Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  events KpiTaskEvent[]

  @@index([criterionId])
  @@index([reviewId, status])
  @@index([assignedToId, status])
}

/// Audit trail for every status change on a KpiTask.
model KpiTaskEvent {
  id        String           @id @default(cuid())
  taskId    String
  task      KpiTask          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User             @relation("KpiTaskEventActor", fields: [actorId], references: [id])
  actorRole String
  eventType KpiTaskEventType
  oldStatus String?
  newStatus String?
  timestamp DateTime         @default(now())
  reason    String?
  metadata  Json?

  @@index([taskId, timestamp])
}

/// Singleton record for admin-configured working hours, breaks, and holidays.
/// id is always "default".
model WorkingCalendar {
  id            String   @id @default("default")
  workStartTime String   @default("10:00")
  workEndTime   String   @default("17:30")
  timezone      String   @default("Asia/Kolkata")
  graceMinutes  Int      @default(30)
  /// int[] — day-of-week indices (0=Sun … 6=Sat); default Mon–Sat [1,2,3,4,5,6]
  workingDays   Json
  /// {start: string, end: string}[] — 24 h "HH:MM" pairs
  breaks        Json
  /// ISO date strings for public holidays
  holidays      Json
  updatedAt     DateTime @updatedAt
  updatedById   String?
  updatedBy     User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────────────────────────────────────
// OT & COMP-OFF MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum OtApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HolidayType {
  NATIONAL
  COMPANY
  RESTRICTED
  WEEKEND
}

enum OtDayType {
  WORKING_DAY
  HOLIDAY
  WEEKEND
}

/// Singleton config for OT module (id = "default").
/// Stores standard hours/day, OT rate per hour, and comp-off slab breakpoints.
model OtSettings {
  id                 String   @id @default("default")
  standardHoursPerDay Decimal @default(8) @db.Decimal(4, 2)
  otRatePerHour      Decimal  @default(100) @db.Decimal(10, 2)
  /// JSON: [{minHours: number, compOffDays: number}] sorted ascending
  compOffSlabs       Json
  updatedAt          DateTime @updatedAt
  updatedById        String?
}

/// Company + public holiday calendar used for OT/comp-off eligibility checks.
model Holiday {
  id          String      @id @default(cuid())
  holidayDate DateTime    @db.Date
  holidayName String
  holidayType HolidayType
  createdAt   DateTime    @default(now())

  @@unique([holidayDate, holidayType])
  @@index([holidayDate])
}

/// Raw biometric attendance import record per employee per date.
model AttendanceLog {
  id                   String   @id @default(cuid())
  employeeId           String
  employee             User     @relation("AttendanceLogs", fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceDate       DateTime @db.Date
  checkIn              DateTime?
  checkOut             DateTime?
  totalHours           Decimal? @db.Decimal(5, 2)
  regularizationStatus String?
  approvalStatus       String   @default("Approved")
  remarks              String?
  createdAt            DateTime @default(now())

  ot EmployeeOt?

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
  @@index([employeeId, attendanceDate])
}

/// Calculated OT / Comp-Off record per employee per attendance date.
model EmployeeOt {
  id               String          @id @default(cuid())
  attendanceLogId  String          @unique
  attendanceLog    AttendanceLog   @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         User            @relation("EmployeeOtRecords", fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceDate   DateTime        @db.Date
  dayType          OtDayType       @default(WORKING_DAY)
  hoursWorked      Decimal         @db.Decimal(5, 2)
  otHours          Decimal         @default(0) @db.Decimal(5, 2)
  otRatePerHour    Decimal         @default(0) @db.Decimal(10, 2)
  otAmount         Decimal         @default(0) @db.Decimal(10, 2)
  compOffDays      Decimal         @default(0) @db.Decimal(4, 2)
  approvalStatus   OtApprovalStatus @default(PENDING)
  approvedById     String?
  approvedBy       User?           @relation("OtApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  rejectionRemarks String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([employeeId, attendanceDate])
  @@index([approvalStatus])
  @@index([attendanceDate])
}

/// LOP (Loss of Pay) days per employee per payroll month.
model EmployeeLop {
  id           String   @id @default(cuid())
  employeeId   String
  employee     User     @relation("EmployeeLopRecords", fields: [employeeId], references: [id], onDelete: Cascade)
  payrollMonth DateTime @db.Date  // first day of month
  lopDays      Decimal  @db.Decimal(5, 2)
  remarks      String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, payrollMonth])
  @@index([payrollMonth])
}
